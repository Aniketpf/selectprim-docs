{
    "index_name": "my-docs-local",
    "start_urls": ["https://selectprim-docs.vercel.app/"],
    "sitemap_urls": ["https://selectprim-docs.vercel.app/sitemap.xml"],
    "allowed_domains": ["selectprim-docs.vercel.app"],
    "selectors": {
        "lvl0": {
            "selector": ".navbar__item.navbar__link--active, .menu__link--active",
            "default_value": "Documentation",
            "global": true
        },
        "lvl1": "article h1",
        "lvl2": "article h2",
        "lvl3": "article h3",
        "lvl4": "article h4",
        "text": "article p, article li"
    },
    "strip_chars": " .,;:#",
    "nb_hits_max": 10000
}
